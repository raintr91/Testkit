      path: '{{path}}',

      bodyContains: {{{json bodyContains}}}

    })

{{/each}}

{{#each clickSteps}}

{{#if (includes testId '{{')}}

    await po.click(resolveTestIdTemplate('{{testId}}', data))

{{else}}

    await po.click('{{testId}}')

{{/if}}

{{/each}}

{{#each networkAssertions}}

    await assertRequestMatches(await networkResponse{{@index}}, {

      method: '{{method}}',

      path: '{{path}}',

      bodyContains: {{{json bodyContains}}}

